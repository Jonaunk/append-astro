---
import { t } from '../lib/translations';
export interface Props { lang?: 'es' | 'en' }
const { lang = 'es' } = Astro.props;
---
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-5">
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between">
    <a href="#" class="flex items-center gap-1">
      <span class="text-white font-mono text-xl font-bold tracking-tight">
        APPEND<span class="text-append-blue-accent">.</span>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#services" class="nav-link">{t('nav.services', lang)}</a>
      <a href="#about" class="nav-link">{t('nav.about', lang)}</a>
      <a href="#process" class="nav-link">{t('nav.process', lang)}</a>
      <button id="lang-toggle" class="p-0 h-8 text-append-metal-light hover:text-white hover:bg-transparent mr-2">
        <svg id="lang-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24" class="inline-block mr-1"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2zm1 17.93A8.001 8.001 0 0020 12h-2a6 6 0 11-12 0H4a8.001 8.001 0 009 7.93v-2.06z"/></svg>
        <span id="lang-label">{lang === 'en' ? 'ES' : 'EN'}</span>
      </button>
      <a href="#contact" class="btn-primary">{t('nav.contact', lang)}</a>
    </div>
    <button id="menu-toggle" class="md:hidden text-white focus:outline-none" aria-label="Toggle menu">
      <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M4 5h16M4 12h16M4 19h16"/></svg>
    </button>
  </nav>
  <div id="mobile-menu" class="md:hidden absolute top-full left-0 w-full bg-append-darker/95 backdrop-blur-lg shadow-lg transition-all duration-300 overflow-hidden max-h-0 opacity-0">
    <div class="flex flex-col p-6 gap-4">
      <a href="#services" class="text-lg py-2 border-b border-append-metal-darker">{t('nav.services', lang)}</a>
      <a href="#about" class="text-lg py-2 border-b border-append-metal-darker">{t('nav.about', lang)}</a>
      <a href="#process" class="text-lg py-2 border-b border-append-metal-darker">{t('nav.process', lang)}</a>
      <div class="flex items-center py-2 border-b border-append-metal-darker">
        <button id="lang-toggle-mobile" class="p-0 h-8 text-append-metal-light hover:text-white hover:bg-transparent">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24" class="mr-1"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2zm1 17.93A8.001 8.001 0 0020 12h-2a6 6 0 11-12 0H4a8.001 8.001 0 009 7.93v-2.06z"/></svg>
          <span id="lang-label-mobile">{lang === 'en' ? 'ES' : 'EN'}</span>
        </button>
      </div>
      <a href="#contact" class="btn-primary mt-4 text-center">{t('nav.contact', lang)}</a>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('max-h-screen', open);
    menu.classList.toggle('opacity-100', open);
    menuIcon.innerHTML = open ? '<path d="M18 6L6 18M6 6l12 12"/>' : '<path d="M4 5h16M4 12h16M4 19h16"/>';
  });
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 10;
    header.classList.toggle('py-3', scrolled);
    header.classList.toggle('bg-append-darker/90', scrolled);
    header.classList.toggle('shadow-md', scrolled);
    header.classList.toggle('py-5', !scrolled);
  });
</script>
